MINIO_HOST=127.0.0.1:9000
MINIO_ACCESS_KEY=<REDACTED>
MINIO_SECRET_KEY=<REDACTED>
MINIO_BUCKET=audit-files
PRELOAD_LEAD_MIN=20

# ── Auto-poller (opción B) — añadido 2026-05-04 18:35 ───────────────
# Polling de api.laconsultoria.cat para auto-programar engagements
# del formulario público sin abrir nada del orchestrator hacia fuera.
AUTO_POLL_ENABLED=true
AUTO_POLL_INTERVAL_MIN=5
AUDIT_API_URL=https://app.laconsultoria.cat
AUDIT_API_USER=auditor
AUDIT_API_PASS=<REDACTED>
# Basic Auth de Traefik en api.laconsultoria.cat (defensa en profundidad).
AUDIT_API_BASIC_USER=
AUDIT_API_BASIC_PASS=<REDACTED>
AUDIT_DEFAULT_TIPO=pentesting_externo
AUDIT_DEFAULT_DURATION_MIN=120

# Token compartido con el API para bypassar Turnstile en llamadas internas
# (auto_poller). Debe coincidir con INTERNAL_AUTH_TOKEN del API service.
INTERNAL_AUTH_TOKEN=<REDACTED>

# Critic adversarial sobre el bucle ReAct del Red. OFF por defecto hasta validar
# en engagement de prueba. Cuando se active, audit logs estructurados van a
# journald (CRITIC_AUDIT prefix) y Wazuh los recoge.
CRITIC_ENABLED=true
CRITIC_EVERY_N=3

# MinIO REMOTO (VPS3) — replica para que el cliente vea los informes en la web.
# Se accede vía tunnel SSH (wazuh-tunnel.service forwardea 127.0.0.1:9100 → vps3:9000)
MINIO_HOST_REMOTO=127.0.0.1:9100
MINIO_ACCESS_KEY_REMOTO=<REDACTED>
MINIO_SECRET_KEY_REMOTO=<REDACTED>
MINIO_BUCKET_REMOTO=audit-files

# === Field-level encryption (pgcrypto pgp_sym) — Fase A 2026-05-22 ===
DB_FIELD_KEY=<REDACTED>
