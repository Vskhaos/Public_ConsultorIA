# ── PostgreSQL (local, sin Docker) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auditoria_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ── MinIO (Docker) ───────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=audit-files
MINIO_SECURE=false          # true si usas HTTPS / S3 real

# ── Para migrar a AWS S3 en el futuro, cambia únicamente esto: ───────────────
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# MINIO_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# MINIO_SECURE=true

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ── Cookies de sesión (A2) ──────────────────────────────────────────────────
# En prod: HTTPS obligatorio → COOKIE_SECURE=true.
# En dev local con http://localhost: COOKIE_SECURE=false (sino el navegador
# rechaza la cookie y no podrás iniciar sesión).
COOKIE_SECURE=true
COOKIE_SAMESITE=lax   # lax|strict|none
